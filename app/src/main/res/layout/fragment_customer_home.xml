<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".ProductCategoryActivity">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <TextView
                android:layout_width="300dp"
                android:layout_height="30dp"
                android:text="How can we be of help today?"
                android:layout_marginTop="30dp"
                android:layout_marginStart="20dp"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />


            <LinearLayout
                android:id="@+id/search_service"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/search_background"
                android:orientation="horizontal">


                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="15dp"
                    android:background="@drawable/vector_search" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Search Service"
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="10dp"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_weight="1"/>


                <LinearLayout
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:background="@drawable/inner_shape">

                    <ImageView
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:src="@drawable/vector_search" />

                </LinearLayout>


            </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tv_browse"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="30dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginTop="20dp"
                android:text="Browse by category"/>


            <LinearLayout
                android:id="@+id/l_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/btn_see_all"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="110dp"
                        android:layout_marginStart="30dp"
                        android:layout_weight="2"
                        android:background="@drawable/rectangle_product"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="35dp"
                            android:background="@drawable/fashion" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:text="Fashion" />


                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"/>

                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="110dp"
                        android:layout_weight="2"
                        android:layout_marginEnd="30dp"
                        android:background="@drawable/rectangle_product"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="35dp"
                            android:background="@drawable/taxi" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:text="Automobile"/>


                    </LinearLayout>



                </LinearLayout>




                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="110dp"
                        android:layout_weight="2"
                        android:layout_marginStart="30dp"
                        android:background="@drawable/rectangle_product"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="35dp"
                            android:background="@drawable/beauty" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:text="Beauticians" />


                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"/>

                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="110dp"
                        android:layout_weight="2"
                        android:layout_marginEnd="30dp"
                        android:background="@drawable/rectangle_product"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="35dp"
                            android:background="@drawable/food" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:text="Catering"/>


                    </LinearLayout>


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="110dp"
                        android:layout_marginStart="30dp"
                        android:layout_weight="2"
                        android:background="@drawable/rectangle_product"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_marginTop="35dp"
                            android:layout_gravity="center"
                            android:background="@drawable/plumbing" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="16sp"
                            android:text="Plumbing"
                            android:textColor="@color/black" />



                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"/>

                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="110dp"
                        android:layout_weight="2"
                        android:layout_marginEnd="30dp"
                        android:background="@drawable/rectangle_product"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_marginTop="35dp"
                            android:layout_gravity="center"
                            android:background="@drawable/cleaning_product" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:text="Cleaning/Laundry"/>


                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>



            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_see_all"
                android:layout_width="110dp"
                android:layout_height="55dp"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="20dp"
                android:layout_marginBottom="70dp"
                android:background="@drawable/purple_button"
                android:text="See All"
                android:textAllCaps="false"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="18sp"/>


        </LinearLayout>

    </ScrollView>

</LinearLayout>